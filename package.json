{
  "name": "@berachain/hub-pol-adapters",
  "version": "2.0.0",
  "description": "Token price adapters for Berachain",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "lint": "eslint --fix ."
  },
  "author": "devs@berachain.com",
  "license": "MIT",
  "dependencies": {
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2"
  },
  "peerDependencies": {
    "viem": "^2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@eslint/json": "^0.11.0",
    "@eslint/markdown": "^6.3.0",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.24.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.1",
    "viem": "2.41.2",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/berachain/hub-pol-adapters.git"
  },
  "bugs": {
    "url": "https://github.com/berachain/hub-pol-adapters/issues"
  },
  "homepage": "https://github.com/berachain/hub-pol-adapters#readme"
}
